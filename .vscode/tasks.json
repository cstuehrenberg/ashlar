{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Full Stack Dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*?(?:ERROR|error).*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*?(npm run dev|Client|Server).*$",
          "endsPattern": "^.*?(listening|started|ready).*$"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start React Frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "client"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*?(?:ERROR|error).*$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*?vite.*$",
          "endsPattern": "^.*?ready in.*$"
        }
      }
    },
    {
      "label": "Start Node Backend",
      "type": "shell",
      "command": "npm",
      "args": ["--prefix", "server", "run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*?(?:ERROR|error).*$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*?Server.*$",
          "endsPattern": "^.*?running on.*$"
        }
      }
    }
  ]
}
